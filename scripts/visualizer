#!/usr/bin/env bash
set -euo pipefail

VISUALIZER_DIR="/Users/andres.alonso29/StudioProjects/RuckusBioBuzz/tools/pedro-visualizer"
HOST="127.0.0.1"
PORT="5173"
URL="http://${HOST}:${PORT}/"

open_url() {
  if [ "${VISUALIZER_NO_OPEN:-0}" = "1" ]; then
    return 1
  fi

  if command -v open >/dev/null 2>&1; then
    open "${URL}" >/dev/null 2>&1 && return 0
  fi

  return 1
}

if curl -fsS "${URL}" >/dev/null 2>&1; then
  echo "Pedro visualizer is already running at ${URL}"
  open_url
  exit 0
fi

cd "${VISUALIZER_DIR}"

if [ ! -d node_modules ] || [ package-lock.json -nt node_modules ]; then
  echo "Installing Pedro visualizer dependencies..."
  npm ci
fi

echo "Starting Pedro visualizer at ${URL}"
npm run dev -- --host "${HOST}" --port "${PORT}" &
server_pid=$!

cleanup() {
  kill "${server_pid}" >/dev/null 2>&1 || true
}
trap cleanup INT TERM EXIT

for _ in {1..60}; do
  if curl -fsS "${URL}" >/dev/null 2>&1; then
    if open_url; then
      echo "Opened ${URL}"
    else
      echo "Ready at ${URL}"
    fi
    wait "${server_pid}"
    exit $?
  fi

  if ! kill -0 "${server_pid}" >/dev/null 2>&1; then
    wait "${server_pid}"
    exit $?
  fi

  sleep 0.25
done

echo "Server did not respond yet; opening ${URL} anyway."
open_url || true
wait "${server_pid}"
